<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>🍻 회식 날짜 투표</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Pretendard', 'Noto Sans KR', sans-serif; background: #f7f7f5; min-height: 100vh; display: flex; align-items: flex-start; justify-content: center; padding: 2rem 1rem; }
  .wrap { width: 100%; max-width: 480px; }
  .card { background: #fff; border-radius: 16px; padding: 1.75rem; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
  .title-area { margin-bottom: 1.5rem; }
  .title-area h1 { font-size: 20px; font-weight: 600; color: #1a1a1a; }
  .title-area p { font-size: 13px; color: #888; margin-top: 5px; }
  .name-row { display: flex; gap: 8px; margin-bottom: 1.25rem; }
  .name-row input {
    flex: 1; padding: 10px 14px; border: 1px solid #e0e0e0;
    border-radius: 10px; font-size: 14px; color: #1a1a1a;
    outline: none; transition: border-color 0.15s;
  }
  .name-row input:focus { border-color: #1D9E75; }
  .name-row input:disabled { background: #f5f5f5; color: #aaa; }
  .vote-btn {
    padding: 0 20px; height: 42px;
    background: #0F6E56; color: #fff;
    border: none; border-radius: 10px;
    font-size: 14px; font-weight: 600; cursor: pointer;
    transition: background 0.15s; white-space: nowrap;
  }
  .vote-btn:hover { background: #085041; }
  .vote-btn:disabled { background: #ddd; color: #aaa; cursor: not-allowed; }
  .sel-count { font-size: 12px; color: #1D9E75; margin-bottom: 10px; min-height: 18px; }
  .dates-grid { display: flex; flex-direction: column; gap: 8px; }
  .date-card {
    display: flex; align-items: center; gap: 12px;
    padding: 13px 14px;
    border: 1px solid #ebebeb;
    border-radius: 12px;
    cursor: pointer;
    background: #fff;
    transition: border-color 0.15s, background 0.15s;
    user-select: none;
  }
  .date-card:hover { border-color: #b2dfcf; }
  .date-card.selected { border: 1.5px solid #1D9E75; background: #f0faf6; }
  .date-card.voted { cursor: default; }
  .date-check {
    width: 20px; height: 20px; border-radius: 5px;
    border: 1.5px solid #d0d0d0;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; background: #fff;
    transition: background 0.15s, border-color 0.15s;
  }
  .date-card.selected .date-check { background: #1D9E75; border-color: #1D9E75; }
  .chk { display: none; }
  .date-card.selected .chk { display: block; }
  .date-info { flex: 1; min-width: 0; }
  .date-main { font-size: 15px; font-weight: 600; color: #1a1a1a; }
  .date-day { font-size: 12px; font-weight: 400; color: #999; margin-left: 5px; }
  .bar-wrap { height: 3px; background: #f0f0f0; border-radius: 2px; margin-top: 6px; overflow: hidden; }
  .bar-fill { height: 3px; background: #1D9E75; border-radius: 2px; transition: width 0.4s; }
  .vote-count { font-size: 13px; color: #999; display: flex; align-items: center; gap: 3px; flex-shrink: 0; }
  .divider { height: 1px; background: #f0f0f0; margin: 1.25rem 0; }
  .result-row { display: flex; align-items: center; justify-content: space-between; }
  .result-label { font-size: 13px; color: #888; }
  .total-badge {
    background: #f0faf6; color: #0F6E56;
    border-radius: 99px; padding: 3px 12px;
    font-size: 12px; font-weight: 600;
  }
  .loading { text-align: center; padding: 2rem; color: #aaa; font-size: 14px; }
  .toast {
    position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
    background: #222; color: #fff;
    padding: 10px 22px; border-radius: 99px;
    font-size: 13px; opacity: 0; transition: opacity 0.2s;
    pointer-events: none; white-space: nowrap; z-index: 999;
  }
  .toast.show { opacity: 1; }
  @media (max-width: 400px) {
    .card { padding: 1.25rem; }
    .date-main { font-size: 14px; }
  }
</style>
</head>
<body>
<div class="wrap">
  <div class="card">
    <div class="title-area">
      <h1>🍻 회식 날짜 투표</h1>
      <p>가능한 날짜를 모두 선택하고 투표해주세요</p>
    </div>

    <div class="name-row">
      <input type="text" id="nameInput" placeholder="이름 입력" />
      <button class="vote-btn" id="submitBtn" onclick="submitVote()" disabled>투표하기</button>
    </div>

    <div class="sel-count" id="selCount"></div>
    <div class="dates-grid" id="datesGrid"><div class="loading">불러오는 중...</div></div>

    <div class="divider"></div>
    <div class="result-row">
      <span class="result-label">실시간 현황</span>
      <span class="total-badge" id="totalBadge">0명 참여</span>
    </div>
  </div>
</div>
<div class="toast" id="toast"></div>

<script>
const SUPABASE_URL = 'https://xudbvniahvlemelpopbm.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh1ZGJ2bmlhaHZsZW1lbHBvcGJtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM4OTY2OTksImV4cCI6MjA4OTQ3MjY5OX0.lIwAM_qWxug2iRSTIIGPvoLRqKPiXUii-UjM_eH3FnY';

const { createClient } = supabase;
const db = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

const dates = [
  { label: '3월 23일', day: '일요일' },
  { label: '3월 24일', day: '월요일' },
  { label: '3월 25일', day: '화요일' },
  { label: '3월 26일', day: '수요일' },
  { label: '3월 27일', day: '목요일' },
  { label: '3월 30일', day: '일요일' },
  { label: '3월 31일', day: '월요일' },
];

let voteCounts = dates.map(() => ({ count: 0, voters: [] }));
let selected = [];
let hasVoted = localStorage.getItem('hoesik_voted_v2') === 'yes';

async function loadVotes() {
  const { data, error } = await db.from('votes').select('date_index, voter_name');
  if (error) { showToast('데이터 불러오기 실패'); return; }

  voteCounts = dates.map(() => ({ count: 0, voters: [] }));
  data.forEach(row => {
    const i = row.date_index;
    if (i >= 0 && i < dates.length) {
      voteCounts[i].count++;
      voteCounts[i].voters.push(row.voter_name);
    }
  });
  render();
}

function render() {
  const grid = document.getElementById('datesGrid');
  const maxVote = Math.max(...voteCounts.map(v => v.count), 1);
  const totalVoters = new Set(voteCounts.flatMap(v => v.voters)).size;

  grid.innerHTML = dates.map((d, i) => {
    const isSel = selected.includes(i);
    const pct = voteCounts[i].count > 0 ? Math.round((voteCounts[i].count / maxVote) * 100) : 0;
    return `
      <div class="date-card ${isSel ? 'selected' : ''} ${hasVoted ? 'voted' : ''}" onclick="toggle(${i})">
        <div class="date-check">
          <svg class="chk" width="12" height="9" viewBox="0 0 12 9" fill="none">
            <path d="M1 4L4.5 7.5L11 1" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="date-info">
          <div class="date-main">${d.label}<span class="date-day">${d.day}</span></div>
          ${voteCounts[i].count > 0 ? `<div class="bar-wrap"><div class="bar-fill" style="width:${pct}%"></div></div>` : ''}
        </div>
        <div class="vote-count">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="5" r="3" stroke="#999" stroke-width="1.3"/>
            <path d="M2 13c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="#999" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          ${voteCounts[i].count}
        </div>
      </div>
    `;
  }).join('');

  document.getElementById('totalBadge').textContent = totalVoters + '명 참여';
  document.getElementById('selCount').textContent = selected.length > 0 ? `${selected.length}개 선택됨` : '';
  document.getElementById('submitBtn').disabled = selected.length === 0 || hasVoted;

  if (hasVoted) {
    document.getElementById('nameInput').disabled = true;
    document.getElementById('nameInput').placeholder = '투표 완료';
  }
}

function toggle(i) {
  if (hasVoted) { showToast('이미 투표했어요'); return; }
  selected = selected.includes(i) ? selected.filter(x => x !== i) : [...selected, i];
  render();
}

async function submitVote() {
  const name = document.getElementById('nameInput').value.trim();
  if (!name) { showToast('이름을 입력해주세요'); return; }
  if (selected.length === 0) { showToast('날짜를 선택해주세요'); return; }
  if (hasVoted) { showToast('이미 투표했어요'); return; }

  document.getElementById('submitBtn').disabled = true;

  const rows = selected.map(i => ({ date_index: i, voter_name: name }));
  const { error } = await db.from('votes').insert(rows);

  if (error) {
    showToast('오류가 발생했어요. 다시 시도해주세요');
    document.getElementById('submitBtn').disabled = false;
    return;
  }

  localStorage.setItem('hoesik_voted_v2', 'yes');
  hasVoted = true;
  showToast('투표 완료! 감사합니다 🎉');
  await loadVotes();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2400);
}

// 실시간 구독 — 다른 사람이 투표하면 자동 갱신
db.channel('votes-channel')
  .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'votes' }, () => {
    loadVotes();
  })
  .subscribe();

loadVotes();
</script>
</body>
</html>
